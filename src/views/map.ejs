<!DOCTYPE html>
<html>

<head>
    <title>Live Location</title>

    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <style>
        .leaflet-marker-icon {
            will-change: transform, opacity;
        }

        .marker-enter {
            transform: scale(0.6);
            opacity: 0;
        }

        .marker-enter-active {
            transform: scale(1);
            opacity: 1;
            transition: all 0.25s ease;
        }


        #toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
        }

        .toast {
            background: #222;
            color: white;
            padding: 10px 14px;
            margin-top: 10px;
            border-radius: 6px;
            font-size: 13px;
            opacity: 0;
            transform: translateY(-10px);
            transition: all 0.3s ease;
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast.success {
            background: #28a745;
        }

        .toast.error {
            background: #dc3545;
        }

        #map {
            height: 100vh;
            width: 100%;
        }

        .incident-form {
            min-width: 220px;
            font-family: system-ui, -apple-system, sans-serif;
            padding: 10px;
        }

        .form-title {
            margin-bottom: 10px;
            font-size: 16px;
            font-weight: 600;
            color: #222;
        }

        .form-group {
            margin-bottom: 10px;
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            font-size: 12px;
            margin-bottom: 4px;
            color: #555;
        }

        .form-group select,
        .form-group textarea {
            padding: 6px 8px;
            border-radius: 6px;
            border: 1px solid #ddd;
            font-size: 13px;
            outline: none;
            transition: border 0.2s ease;
        }

        .form-group select:focus,
        .form-group textarea:focus {
            border-color: #007bff;
        }

        .form-group textarea {
            resize: none;
            min-height: 60px;
        }

        .submit-btn {
            width: 100%;
            padding: 8px;
            border: none;
            border-radius: 6px;
            background: #007bff;
            color: white;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.2s ease;
        }

        .submit-btn:hover {
            background: #0056b3;
        }

        .submit-btn:disabled {
            background: #aaa;
            cursor: not-allowed;
        }

        .btn-loader {
            width: 16px;
            height: 16px;
            border: 2px solid white;
            border-top: 2px solid white;
            border-radius: 50%;
            display: inline-block;
            animation: spin 0.8s linear infinite;
            margin-left: 6px;
        }

        .hidden {
            display: none;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .button {
            align-items: center;
            background-color: #fee6e3;
            border: 2px solid #111;
            border-radius: 8px;
            box-sizing: border-box;
            color: #111;
            cursor: pointer;
            display: flex;
            font-family: Inter, sans-serif;
            font-size: 16px;
            height: 48px;
            justify-content: center;
            line-height: 24px;
            max-width: 100%;
            padding: 0 25px;
            position: relative;
            text-align: center;
            text-decoration: none;
            user-select: none;
            -webkit-user-select: none;
            touch-action: manipulation;
        }

        .button:after {
            background-color: #111;
            border-radius: 8px;
            content: "";
            display: block;
            height: 48px;
            left: 0;
            width: 100%;
            position: absolute;
            top: -2px;
            transform: translate(8px, 8px);
            transition: transform .2s ease-out;
            z-index: -1;
        }

        .button:hover:after {
            transform: translate(0, 0);
        }

        .button:active {
            background-color: #ffdeda;
            outline: 0;
        }

        .button:hover {
            outline: 0;
        }

        @media (min-width: 768px) {
            .button {
                padding: 0 40px;
            }
        }

        .my-label {
            background-color: rgba(0, 0, 0, 0.7);
            color: white;
            border: transparent;
            border-radius: 6px;
            box-shadow: none;
            font-weight: bold;
            font-size: 11px;
            padding: 3px 6px;
            /* Adjust offset here if 'direction: top' isn't perfect */
            transform: translateY(-20px);
        }

        #toggle-layer-btn {
            position: fixed;
            margin: 20px;

            bottom: 20px;
            left: 20px;
            z-index: 99999;
            padding: 8px 12px;
            border: none;
            border-radius: 6px;
            background: #222;
            color: white;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div id="map">
        <button id="toggle-layer-btn">Show Heatmap</button>
    </div>

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>


    <!-- clustering for incident and cdn for performance  -->
    <script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css" />
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>



    <script type="module">



        function animateMarker(marker) {
            setTimeout(() => {
                const el = marker.getElement();
                if (!el) return;
                el.classList.add("marker-enter");
                requestAnimationFrame(() => {
                    el.classList.add("marker-enter-active");
                })
            }, 0);
        }
        function getDistance(lat1, lon1, lat2, lon2) {
            //haversine distance formula
            const R = 6371e3;
            const toRad = (x) => (x * Math.PI) / 180;

            const dLat = toRad(lat2 - lat1);
            const dLon = toRad(lon2 - lon1);

            const a =
                Math.sin(dLat / 2) ** 2 +
                Math.cos(toRad(lat1)) *
                Math.cos(toRad(lat2)) *
                Math.sin(dLon / 2) ** 2;

            return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)));
        }
        function getIncidentIcon(type) {
            const colorMap = {
                theft: "orange",
                accident: "red",
                harassment: "purple",
                other: "blue",
            };

            const color = colorMap[type] || "red";

            return L.icon({
                iconUrl: `https://maps.google.com/mapfiles/ms/icons/${color}-dot.png`,
                iconSize: [32, 32],
            });
        }

        import { initMapActions } from "/js/map-actions.js";
        import { openIncidentForm, showToast } from "/js/incident-form.js";
        import { renderHeatmap, toggleHeatmap } from "/js/heatmap.js";
        const map = L.map("map").setView([0, 0], 15);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: "Indian Tourist Safety",
        }).addTo(map);

        const marker = L.marker([0, 0]).addTo(map);
        animateMarker(marker);
        const token = "<%=token%>";
        const userName = "<%=user%>";
        const currentUserId = "<%=userId%>";


        marker.bindTooltip(`${userName} (you)`, {
            permanent: true,
            direction: 'top',
            className: "my-label"
        }).openTooltip();

        const socket = io("/", {
            auth: {
                token: token
            }
        });
        socket.on("connect", () => {
            console.log("Socket connected: ", socket.id);
        });
        socket.on("connect_error", (err) => {
            console.error("Socket connection error:", err.message);
        });


        let lastPosition = null;
        let initialfetch = false;



        //Get live location
        if (navigator.geolocation) {
            navigator.geolocation.watchPosition(
                (position) => {
                    console.log("Watch Triggered")
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;

                    console.log("Location:", lat, lng);

                    // update marker
                    //marker moves live
                    marker.setLatLng([lat, lng]);

                    // move map
                    //camera follows user

                    //set map view only first time
                    map.setView([lat, lng], 16);


                    if (lastPosition) {
                        const distance = getDistance(
                            lastPosition.lat,
                            lastPosition.lng,
                            lat,
                            lng
                        );
                        // if(distance<20) return;//skip small movement
                        if (distance > 1) {
                            socket.emit("send-location", {
                                latitude: lat,
                                longitude: lng,
                            });

                        }

                    } else {
                        socket.emit("send-location", {
                            latitude: lat,
                            longitude: lng,
                        });
                    }
                    lastPosition = { lat, lng };

                    if(!initialfetch){
                        initialfetch=true;
                        fetchIncidents();
                    }
                },
                (error) => {
                    console.error(error);
                },
                {
                    enableHighAccuracy: true,
                    maximumAge: 0,
                    timeout: 5000,
                }
            );
        } else {
            alert("Geolocation not supported");
        }

        const markers = new Map();

        function updateNearbyMarkers(users) {
            users.forEach(user => {
                const [lng, lat] = user.coordinates;

                if (markers.has(user.userId)) {
                    markers.get(user.userId).setLatLng([lat, lng]);
                } else {
                    const usersmarker = L.marker([lat, lng], {
                        icon: L.icon({
                            iconUrl: "https://maps.google.com/mapfiles/ms/icons/yellow-dot.png",
                            iconSize: [32, 32],
                        })
                    }).addTo(map);
                    animateMarker(usersmarker);
                    usermarker.bindTooltip(user.name, {
                        permanent: true,
                        direction: 'top',
                        className: "my-label"
                    });
                    markers.set(user.userId, usersmarker);
                }
            });
        }

        setInterval(async () => {
            if (!lastPosition) return;

            try {
                const res = await fetch(
                    `/api/locations/nearby?lat=${lastPosition.lat}&lng=${lastPosition.lng}`, {
                    header: {
                        authoriztion: `Bearer ${token}`,
                    },
                }
                );
                // console.log(res);
                const data = await res.json();
                if (data.success) {
                    updateNearbyMarkers(data.data);
                }
            } catch (error) {
                console.error("Nearby fetch error:", error);
            }
        }, 5000);
        function generateSignature(incidents) {
            return incidents
                .map(i => `${i.type}-${i.coordinates[0]}-${i.coordinates[1]}`)
                .sort()
                .join("|");
        }
        let previousSignature = "";

        const incidentMarkers = [];
        const layerState = {
            isHeatmapVisible: false,
        };

        async function fetchIncidents() {
            if (!lastPosition) return;
            try {
                const res = await fetch(`/api/incidents/nearby?lat=${lastPosition.lat}&lng=${lastPosition.lng}`, {
                    headers: {
                        authoriztion: `Bearer ${token}`,
                    },
                });
                const data = await res.json();

                if (data.success) {
                    const newSignature = generateSignature(data.data);
                    if (newSignature !== previousSignature) {
                        previousSignature = newSignature;
                        renderIncidents(data.data);
                        renderHeatmap(map, data.data, layerState.isHeatmapVisible);
                    }
                    // else{
                    //     console.log("no change no render in incidents")
                    // }
                    //else no change skip render;
                }
            } catch (err) {
                console.log(err);
            }
        }


        const clusterGroup = L.markerClusterGroup({
            disableClusteringAtZoom: 16,
            maxClusterRadius: 30,
            spiderfyonMaxZoom: true,
            // zoomToBoundsOnClick: true,
            // showCoverageOnHover:false,
            iconCreateFunction: function (cluster) {
                return L.divIcon({
                    html: `<div style="background:red;color:white;border-radius:50%;padding:10px;">
                            ${cluster.getChildCount()}
                           </div>`,
                    className: "custom-cluster",
                    iconSize: L.point(40, 40)
                });
            }
        });

        map.addLayer(clusterGroup);

        function renderIncidents(incidents) {
            //clear old markers
            console.log(incidents);
            clusterGroup.clearLayers();
            // const zoom=map.getZoom();

            incidentMarkers.length = 0;
            incidents.forEach((i, index) => {
                let [lng, lat] = i.coordinates;

                const offset = (index % 5) * 0.00009;
                lat += offset;
                lng += offset;
                const isOwner = i.user?.toString() === currentUserId;

                const popupContent = `
                <b>${i.type}</b><br/> ${i.description || "no description given..."}
                ${isOwner ? `
                <br/><br/>
                <div style="display:flex; gap:6px; margin-top:6px;">
                    <button 
                        onclick="window.openEditForm('${i._id}', '${i.type}', \`${i.description || ""}\`)"
                        style="padding:5px 10px; cursor:pointer; border:1px solid #ccc; border-radius:4px; background:#f8f9fa;">
                        ✏️ Edit
                    </button>
                    <button 
                        onclick="window.deleteIncident('${i._id}')"
                        style="padding:5px 10px; cursor:pointer; background:#dc3545; color:white; border:none; border-radius:4px;">
                        🗑️ Delete
                    </button>
                </div>    
                `: ""}
                `

                const incidentmarker = L.marker([lat, lng], {
                    icon: getIncidentIcon(i.type),
                });
                incidentmarker.bindPopup(popupContent);
                incidentMarkers.push(incidentmarker);
                clusterGroup.addLayer(incidentmarker);
                animateMarker(incidentmarker);
            });
        }

        fetchIncidents();
        setInterval(fetchIncidents, 10000);


        initMapActions(map, token, clusterGroup, getIncidentIcon, animateMarker);


        document.getElementById("toggle-layer-btn").onclick = () => {
            layerState.isHeatmapVisible = !layerState.isHeatmapVisible;

            toggleHeatmap(map, clusterGroup, layerState);

            document.getElementById("toggle-layer-btn").innerText =
                layerState.isHeatmapVisible ? "Show Markers" : "Show Heatmap";

            showToast(
                layerState.isHeatmapVisible
                    ? "Heatmap enabled"
                    : "Markers enabled"
            );
        };

        window.openEditForm = (id, type, description) => {
            const formHtml = `
        <div class="incident-form">
            <h4 class="form-title">Edit Incident</h4>
            <div class="form-group">
                <label>Type</label>
                <select id="edit-type">
                    <option value="theft"      ${type === "theft" ? "selected" : ""}>Theft</option>
                    <option value="accident"   ${type === "accident" ? "selected" : ""}>Accident</option>
                    <option value="harassment" ${type === "harassment" ? "selected" : ""}>Harassment</option>
                    <option value="other"      ${type === "other" ? "selected" : ""}>Other</option>
                </select>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea id="edit-desc" placeholder="Describe what happened...">${description}</textarea>
            </div>
            <div style="display:flex; gap:6px;">
                <button id="save-edit-btn" class="submit-btn">
                    <span class="btn-text">Save</span>
                    <span class="btn-loader hidden"></span>
                </button>
                <button id="cancel-edit-btn" class="submit-btn" style="background:#6c757d;">
                    Cancel
                </button>
            </div>
        </div>`;

            L.popup({ minWidth: 300 })
                .setLatLng(map.getCenter())
                .setContent(formHtml)
                .openOn(map);

            setTimeout(() => {
                document.getElementById("cancel-edit-btn").onclick = () => {
                    map.closePopup();
                };

                const saveBtn = document.getElementById("save-edit-btn");
                saveBtn.onclick = async () => {
                    const updatedType = document.getElementById("edit-type").value;
                    const updatedDesc = document.getElementById("edit-desc").value;

                    saveBtn.disabled = true;
                    saveBtn.querySelector(".btn-text").style.display = "none";
                    saveBtn.querySelector(".btn-loader").classList.remove("hidden");

                    try {
                        const res = await fetch(`/api/incidents/${id}`, {
                            method: "PATCH",
                            headers: {
                                "Content-Type": "application/json",
                                authorization: `Bearer ${token}`,
                            },
                            body: JSON.stringify({
                                type: updatedType,
                                description: updatedDesc,
                            }),
                        });
                        const data = await res.json();

                        if (data.success) {
                            map.closePopup();
                            previousSignature = "";
                            fetchIncidents();
                            showToast("Incident updated successfully", "success"); // ✅
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        console.error(err);
                        showToast(err.message || "Failed to update incident", "error"); // ✅
                    } finally {
                        saveBtn.disabled = false;
                        saveBtn.querySelector(".btn-text").style.display = "inline";
                        saveBtn.querySelector(".btn-loader").classList.add("hidden");
                    }
                };
            }, 0);
        };

        window.deleteIncident = async (id) => {
            if (!confirm("Are you sure you want to delete this incident?")) return;

            try {
                const res = await fetch(`/api/incidents/${id}`, {
                    method: "DELETE",
                    headers: {
                        authorization: `Bearer ${token}`,
                    },
                });
                const data = await res.json();

                if (data.success) {
                    map.closePopup();
                    fetchIncidents();
                    showToast("Incident deleted successfully", "success"); 
                } else {
                    throw new Error(data.message);
                }
            } catch (err) {
                console.error(err);
                showToast(err.message || "Failed to delete incident", "error"); // ✅
            }
        };



    </script>

    <div id="toast-container"></div>


</body>

</html>